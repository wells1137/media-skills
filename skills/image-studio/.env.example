# ── Client-side (optional) ──────────────────────────────────────────────────
# Custom proxy URL — leave empty to use the default hosted proxy
# IMAGE_STUDIO_PROXY_URL=https://your-proxy.vercel.app/api/image

# Pro access key for custom proxy authentication
# IMAGE_STUDIO_API_KEY=your_pro_key_here

# ── Server-side (only needed if self-hosting the proxy) ─────────────────────
# fal.ai API Key — required for Flux, SDXL, Nano Banana, Ideogram, Recraft
# Get it at: https://fal.ai/dashboard/keys
# FAL_KEY=your_fal_key_here

# Legnext.ai API Key — required for Midjourney
# Get it at: https://legnext.ai/dashboard
# LEGNEXT_KEY=your_legnext_key_here

# Comma-separated list of valid pro keys for access control (leave empty for open access)
# VALID_PRO_KEYS=key1,key2,key3
